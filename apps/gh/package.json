{
  "name": "gh",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "gh": "./dist/main/bin.js"
  },
  "exports": {
    "./app": {
      "types": "./dist/main/app.d.ts",
      "import": "./dist/main/app.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    }
  },
  "cmdless": {
    "main": "./dist/main/bin.js",
    "mainDev": "./src/main/bin.ts",
    "renderer": "./dist/renderer/index.html"
  },
  "scarfSettings": {
    "enabled": false
  },
  "scripts": {
    "dev": "npm run build && node scripts/dev.mjs",
    "prebuild": "rimraf dist node_modules/.tmp",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@cmdless/sdk": "0.0.2",
    "@cmdless/ui": "*",
    "octokit": "^5.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14",
    "swagger-ui-react": "5.32.8"
  },
  "devDependencies": {
    "@types/swagger-ui-react": "5.18.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "tsx": "^4.8.1",
    "vite": "^8.1.0"
  }
}
