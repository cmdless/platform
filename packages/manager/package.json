{
  "name": "@cmdless/manager",
  "description": "Manages cross platform cmdless apps and their runtimes.",
  "version": "0.0.2",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Fluttershy",
    "url": "https://github.com/Fluttershy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmdless/platform.git"
  },
  "bin": {
    "sdk": "./dist/main/sdk.js"
  },
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist node_modules/.tmp",
    "build": "tsc -b",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {}
}